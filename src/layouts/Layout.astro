---
import '../styles/global.css';
import StarField from '../components/StarField.astro';
import { CursorGlow } from '../components/ui/cursor-glow';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Kshitij Betwal — Builder & AI Developer',
  description = 'Builder Resident at Zeoxia. I ship ML systems, edge computing, and developer infrastructure — mostly Python, TypeScript, and Go.',
} = Astro.props;

const siteUrl = 'https://theneuralhorizon.github.io/portfolio';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#030303" />
    <meta name="color-scheme" content="dark" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={siteUrl} />
    <link rel="icon" type="image/svg+xml" href="/portfolio/favicon.svg" />

    <!-- Fonts: preconnect + preload for critical weight -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org', '@type': 'Person',
      name: 'Kshitij Betwal', url: siteUrl, jobTitle: 'Builder & AI Developer',
      sameAs: ['https://linkedin.com/in/kshitijbetwal', 'https://github.com/theNeuralHorizon'],
    })} />
  </head>
  <body class="min-h-screen bg-[#030303] grid-overlay">
    <!-- Cursor glow: desktop only, idle hydration -->
    <CursorGlow client:media="(hover: hover) and (pointer: fine)" />

    <StarField />
    <slot />

    <!-- Global scripts: guard heavy handlers for touch/mobile -->
    <script>
      // Helper: detect desktop (hover + fine pointer)
      const isDesktop = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // ── Scroll-reveal observer (all devices) ──
      const revealObserver = new IntersectionObserver(
        (entries) => entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            revealObserver.unobserve(e.target);
          }
        }),
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('[data-animate]').forEach((el) => revealObserver.observe(el));

      // ── 3D Tilt: desktop-only, respects reduced-motion ──
      if (isDesktop && !reducedMotion) {
        const tiltCards = document.querySelectorAll('.tilt-card');
        tiltCards.forEach((card) => {
          const el = card as HTMLElement;
          let raf: number | null = null;
          el.addEventListener('mousemove', (e) => {
            if (raf) cancelAnimationFrame(raf);
            raf = requestAnimationFrame(() => {
              const rect = el.getBoundingClientRect();
              const x = (e.clientX - rect.left) / rect.width - 0.5;
              const y = (e.clientY - rect.top) / rect.height - 0.5;
              el.style.transform = `perspective(600px) rotateX(${-y * 5}deg) rotateY(${x * 5}deg) scale(1.015)`;
            });
          });
          el.addEventListener('mouseleave', () => {
            if (raf) cancelAnimationFrame(raf);
            el.style.transform = '';
            el.style.transition = 'transform 0.4s ease-out';
            setTimeout(() => { el.style.transition = ''; }, 400);
          });
        });
      }

      // ── Konami Code: desktop only (keyboard required) ──
      if (isDesktop) {
        const konami = [38, 38, 40, 40, 37, 39, 37, 39, 66, 65];
        let pos = 0;
        document.addEventListener('keydown', (e) => {
          if (e.keyCode === konami[pos]) {
            pos++;
            if (pos === konami.length) {
              pos = 0;
              document.dispatchEvent(new CustomEvent('hyperdrive'));
            }
          } else {
            pos = 0;
          }
        });
      }
    </script>
  </body>
</html>
