---
import '../styles/global.css';
import StarField from '../components/StarField.astro';
import { CursorGlow } from '../components/ui/cursor-glow';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Kshitij Betwal, Builder & AI Developer',
  description = 'Builder Resident at Zeoxia. I ship ML systems, edge computing, and developer infrastructure, mostly Python, TypeScript, and Go.',
} = Astro.props;

const siteUrl = Astro.site?.toString() ?? 'https://theneuralhorizon.github.io/portfolio';
const faviconUrl = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0b" />
    <meta name="color-scheme" content="dark" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={siteUrl} />
    <link rel="icon" type="image/svg+xml" href={faviconUrl} />

    <!-- Fonts: cinematic stack, display, serif italic, mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Space+Grotesk:wght@400;500;600;700&family=Inter+Tight:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap"
    />

    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org', '@type': 'Person',
      name: 'Kshitij Betwal', url: siteUrl, jobTitle: 'Builder & AI Developer',
      sameAs: ['https://linkedin.com/in/kshitijbetwal', 'https://github.com/theNeuralHorizon'],
    })} />
  </head>
  <body class="min-h-screen">
    <!-- Cursor glow: desktop only, idle hydration -->
    <CursorGlow client:media="(hover: hover) and (pointer: fine)" />

    <StarField />
    <slot />
  </body>
</html>
