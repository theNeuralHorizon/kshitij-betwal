---
import GitHub from './icons/GitHub.astro';
import LinkedIn from './icons/LinkedIn.astro';
import Mail from './icons/Mail.astro';
---

<footer class="border-t border-[var(--color-border)] mt-8">
  <div class="max-w-6xl mx-auto px-6 py-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 text-[11px] font-mono text-[var(--color-text-dim)]">
    <div class="flex items-center gap-3">
      <span class="font-[var(--font-display)] font-bold text-[var(--color-text-muted)] text-xs">KB</span>
      <span>&copy; {new Date().getFullYear()} Kshitij Betwal</span>
    </div>

    <div class="flex items-center gap-3 order-3 sm:order-2">
      <a href="/portfolio/cli/" class="hover:text-[var(--color-text)] transition-colors tap-target inline-flex items-center">&gt;_ Terminal</a>
      <span class="text-[var(--color-border)]">|</span>
      <span class="flex items-center gap-1.5">
        <span class="w-1 h-1 rounded-full bg-[var(--color-green)]"></span>
        SYSTEM ONLINE
      </span>
    </div>

    <div class="flex items-center gap-4 sm:gap-3 order-2 sm:order-3">
      <a href="https://github.com/theNeuralHorizon" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-text)] transition-colors tap-target inline-flex items-center justify-center" aria-label="GitHub"><GitHub class="w-4 h-4" /></a>
      <a href="https://linkedin.com/in/kshitijbetwal" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-text)] transition-colors tap-target inline-flex items-center justify-center" aria-label="LinkedIn"><LinkedIn class="w-4 h-4" /></a>
      <a href="mailto:kshitij.betwal@gmail.com" class="hover:text-[var(--color-text)] transition-colors tap-target inline-flex items-center justify-center" aria-label="Email"><Mail class="w-4 h-4" /></a>
    </div>
  </div>
</footer>
