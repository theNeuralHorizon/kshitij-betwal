---
const techs = [
  'Python', 'C++', 'JavaScript', 'TypeScript', 'SQL',
  'FastAPI', 'React.js', 'Node.js', 'Tailwind', 'PyTorch',
  'Scikit-learn', 'AWS', 'Docker', 'Git', 'Linux',
  'PostgreSQL', 'Power BI', 'ML', 'NLP', 'CI/CD',
];
const all = [...techs, ...techs];
---

<div class="marquee-container py-4" data-animate>
  <div class="marquee-track">
    {all.map((t) => (
      <span class="shrink-0 px-3 py-1.5 bg-[var(--color-deep)] border border-[var(--color-border)] rounded text-xs text-[var(--color-text-dim)] font-mono whitespace-nowrap hover:border-[var(--color-border-active)] hover:text-[var(--color-text-muted)] transition-colors cursor-default">
        {t}
      </span>
    ))}
  </div>
</div>
