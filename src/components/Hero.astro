---
import GitHub from './icons/GitHub.astro';
import LinkedIn from './icons/LinkedIn.astro';
import Mail from './icons/Mail.astro';
import Download from './icons/Download.astro';
import { SplineScene } from './ui/splite';
import { Spotlight } from './ui/spotlight';
import { MagneticButton } from './ui/magnetic-button';
---

<section id="hero" class="relative min-h-screen overflow-hidden flex items-center">
  <Spotlight className="-top-40 left-0 md:left-60 md:-top-20" fill="rgba(34, 211, 238, 0.15)" />

  <!-- 3D Robot — desktop only (lg and up). client:media means it never loads on mobile. -->
  <div class="absolute top-0 right-0 w-[55%] h-full hidden lg:block">
    <SplineScene
      scene="https://prod.spline.design/kZDDjO5HuC9GJUM2/scene.splinecode"
      className="w-full h-full"
      client:media="(min-width: 1024px)"
    />
    <div class="absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-[#030303] to-transparent pointer-events-none"></div>
  </div>

  <!-- Content — centered on mobile, left on desktop -->
  <div class="relative z-10 w-full pointer-events-none">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-xl stagger pointer-events-auto py-16 lg:py-0">
        <div data-animate class="sys-label mb-6 flex items-center gap-3">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-green)]"></span>
          HELLO &middot; BENGALURU &middot; 12.97&deg;N
        </div>

        <h1 data-animate class="display-hero text-[var(--color-text)] mb-6">
          Kshitij<br />Betwal
        </h1>

        <p data-animate class="text-[var(--color-text-muted)] text-base sm:text-lg lg:text-xl max-w-lg mb-8 leading-relaxed">
          Builder Resident at <span class="text-[var(--color-text)]">Zeoxia</span>, working across
          ML systems and edge infrastructure. I build things that ship &mdash; and occasionally
          break them on purpose to see where they hold.
        </p>

        <!-- CTAs: magnetic on desktop only -->
        <div data-animate class="flex flex-wrap gap-3 mb-10">
          <MagneticButton client:media="(hover: hover) and (pointer: fine)">
            <a href="#projects" class="px-5 py-3 border border-[var(--color-border)] text-[var(--color-text)] text-sm hover:border-[var(--color-cyan)] hover:text-[var(--color-cyan)] transition-all rounded-md block tap-target">
              View Projects
            </a>
          </MagneticButton>
          <MagneticButton client:media="(hover: hover) and (pointer: fine)">
            <a href="/portfolio/resume.pdf" download class="px-5 py-3 border border-[var(--color-amber)]/30 text-[var(--color-amber)] text-sm hover:border-[var(--color-amber)] transition-all rounded-md inline-flex items-center gap-2 tap-target">
              <Download class="w-3.5 h-3.5" /> Resume
            </a>
          </MagneticButton>
          <MagneticButton client:media="(hover: hover) and (pointer: fine)">
            <a href="/portfolio/cli/" class="group px-5 py-3 border border-[var(--color-border)] text-[var(--color-text-muted)] text-sm hover:border-[var(--color-text-dim)] transition-all rounded-md font-mono block tap-target" id="terminal-cta">
              <span class="terminal-text">&gt;_ terminal</span>
            </a>
          </MagneticButton>
        </div>

        <div data-animate class="flex items-center gap-5">
          <a href="https://github.com/theNeuralHorizon" target="_blank" rel="noopener noreferrer" class="text-[var(--color-text-dim)] hover:text-[var(--color-text)] transition-colors" aria-label="GitHub"><GitHub class="w-5 h-5" /></a>
          <a href="https://linkedin.com/in/kshitijbetwal" target="_blank" rel="noopener noreferrer" class="text-[var(--color-text-dim)] hover:text-[var(--color-text)] transition-colors" aria-label="LinkedIn"><LinkedIn class="w-5 h-5" /></a>
          <a href="mailto:kshitij.betwal@gmail.com" class="text-[var(--color-text-dim)] hover:text-[var(--color-text)] transition-colors" aria-label="Email"><Mail class="w-5 h-5" /></a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Typing effect on terminal CTA hover — desktop only
  const termCta = document.getElementById('terminal-cta');
  const isDesktop = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
  if (termCta && isDesktop) {
    const original = '>_ terminal';
    const command = '>_ ./explore --portfolio';
    let typing = false;

    termCta.addEventListener('mouseenter', () => {
      if (typing) return;
      typing = true;
      const span = termCta.querySelector('.terminal-text');
      if (!span) return;
      span.textContent = '>_ ';
      let i = 3;
      const interval = setInterval(() => {
        if (i < command.length) {
          span.textContent = command.substring(0, i + 1);
          i++;
        } else {
          clearInterval(interval);
        }
      }, 40);

      termCta.addEventListener('mouseleave', () => {
        clearInterval(interval);
        span.textContent = original;
        typing = false;
      }, { once: true });
    });
  }
</script>
