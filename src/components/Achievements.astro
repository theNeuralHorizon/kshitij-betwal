---
const items = [
  { num: '01', title: 'HackBricks 2026 — Databricks × Manipal', detail: 'Built drifting-oracle: dual-loop ML observability for credit risk with PSI-based drift detection + LLM hallucination monitoring' },
  { num: '02', title: 'Meta × HuggingFace × PyTorch OpenEnv Hackathon', detail: 'Designed IncidentEnv — an RL environment for AI SRE agents with 12-command action space and rubric-based grading' },
  { num: '03', title: 'MIT / Artpark Robotics Hackathon', detail: 'Advanced to R3 with mobilityyy — map-less exploration-based autonomous navigation on ROS 2 Jazzy + Gazebo Harmonic' },
  { num: '04', title: 'Honeywell Hackathon — Top 10', detail: 'Recognized for real-time systems design, 2025' },
];
---

<section id="achievements" class="section-wrap">
  <div class="sys-label mb-4" data-animate>// HIGHLIGHTS</div>
  <h2 data-animate class="display-section text-[var(--color-text)] mb-3">
    Recognition
  </h2>
  <p data-animate class="text-[var(--color-text-muted)] text-base sm:text-lg mb-10 max-w-xl">
    Hackathons and competitions where the long nights paid off. Powered in equal parts by
    curiosity and questionable amounts of coffee.
  </p>

  <div class="space-y-0">
    {items.map((item, i) => (
      <div class:list={['flex items-baseline gap-6 py-5', i > 0 && 'border-t border-[var(--color-border)]']} data-animate>
        <span class="font-mono text-sm text-[var(--color-text-dim)] tabular-nums shrink-0">{item.num}</span>
        <div>
          <span class="text-[var(--color-text)] font-semibold text-base">{item.title}</span>
          <p class="text-[var(--color-text-muted)] text-sm mt-1">{item.detail}</p>
        </div>
      </div>
    ))}
  </div>
</section>
