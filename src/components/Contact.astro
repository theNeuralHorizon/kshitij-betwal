---
import { BookingCalendar } from './ui/booking-calendar';
import RotatingEarth from './ui/wireframe-dotted-globe';
---

<section id="contact" class="section-wrap">
  <div class="sys-label mb-4" data-animate>// CONTACT</div>
  <h2 data-animate class="display-section text-[var(--color-text)] mb-3">
    Get in Touch
  </h2>
  <p data-animate class="text-[var(--color-text-muted)] text-base sm:text-lg mb-10 max-w-2xl leading-relaxed">
    Open to roles, internships, research collaborations, or a thoughtful exchange about a
    paper you're reading. Email is the fastest channel &mdash; I typically reply within a day,
    faster if it's interesting.
  </p>

  <!-- Globe: desktop only (hydrates on visibility + min-width gate) -->
  <div class="mb-10 justify-center hidden md:flex" data-animate>
    <RotatingEarth width={500} height={400} client:media="(min-width: 768px)" />
  </div>

  <div class="grid lg:grid-cols-2 gap-6">
    <!-- Contact info panel -->
    <div class="panel p-6" data-animate>
      <div class="flex items-center gap-2 mb-5 pb-3 border-b border-[var(--color-border)]">
        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-green)]"></span>
        <span class="font-mono text-[10px] text-[var(--color-green)] tracking-widest">SIGNAL: STRONG</span>
      </div>

      <div class="space-y-3 font-mono text-sm">
        <div class="flex items-baseline gap-3 flex-wrap">
          <span class="text-[var(--color-text-dim)] w-16 shrink-0 text-[11px]">EMAIL</span>
          <a href="mailto:kshitij.betwal@gmail.com" class="text-[var(--color-text)] hover:text-[var(--color-cyan)] transition-colors break-all">
            kshitij.betwal@gmail.com
          </a>
        </div>
        <div class="flex items-baseline gap-3 flex-wrap">
          <span class="text-[var(--color-text-dim)] w-16 shrink-0 text-[11px]">GITHUB</span>
          <a href="https://github.com/theNeuralHorizon" target="_blank" rel="noopener noreferrer" class="text-[var(--color-text)] hover:text-[var(--color-cyan)] transition-colors">
            theNeuralHorizon
          </a>
        </div>
        <div class="flex items-baseline gap-3 flex-wrap">
          <span class="text-[var(--color-text-dim)] w-16 shrink-0 text-[11px]">LINKED</span>
          <a href="https://linkedin.com/in/kshitijbetwal" target="_blank" rel="noopener noreferrer" class="text-[var(--color-text)] hover:text-[var(--color-cyan)] transition-colors">
            kshitijbetwal
          </a>
        </div>
        <div class="flex items-baseline gap-3 flex-wrap">
          <span class="text-[var(--color-text-dim)] w-16 shrink-0 text-[11px]">COORDS</span>
          <span class="text-[var(--color-text-muted)]">Bengaluru, India &mdash; 12.97&deg;N, 77.59&deg;E</span>
        </div>
      </div>

      <div class="mt-6 pt-4 border-t border-[var(--color-border)]">
        <a href="mailto:kshitij.betwal@gmail.com"
          class="inline-flex items-center gap-2 px-6 py-3 border border-[var(--color-cyan)]/30 text-[var(--color-cyan)] text-sm hover:border-[var(--color-cyan)] hover:bg-[var(--color-cyan)]/5 transition-all rounded-md font-mono tracking-wider uppercase text-xs tap-target">
          Establish Connection
        </a>
      </div>
    </div>

    <!-- Booking Calendar: lazy hydrate when visible -->
    <div data-animate>
      <BookingCalendar client:visible />
    </div>
  </div>
</section>
