---
import GitHub from './icons/GitHub.astro';
---

<section class="section-wrap">
  <div class="sys-label mb-4" data-animate>// GIT LOG</div>
  <h2 data-animate class="display-section text-[var(--color-text)] mb-3">
    GitHub Activity
  </h2>
  <p data-animate class="text-[var(--color-text-muted)] text-base sm:text-lg mb-8 max-w-xl">
    A year of public commits &mdash; arguably the clearest signal of whether someone actually ships.
  </p>

  <div class="panel p-5" data-animate>
    <div class="flex items-center justify-between mb-4">
      <a href="https://github.com/theNeuralHorizon" target="_blank" rel="noopener noreferrer"
        class="flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors">
        <GitHub class="w-4 h-4" /> @theNeuralHorizon
      </a>
      <span class="font-mono text-[10px] text-[var(--color-text-dim)]">52 WEEKS</span>
    </div>

    <div class="overflow-x-auto pb-2 -mx-2 px-2" style="scrollbar-width: thin;">
      <svg id="contrib-graph" width="722" height="112" class="min-w-[722px]" role="img" aria-label="GitHub contribution graph"></svg>
    </div>

    <div class="flex items-center justify-between mt-2">
      <span class="font-mono text-[10px] text-[var(--color-text-dim)]" id="contrib-count"></span>
      <div class="flex items-center gap-1 text-[10px] text-[var(--color-text-dim)] font-mono">
        <span>Less</span>
        <span class="w-2.5 h-2.5 rounded-sm bg-[var(--color-surface)]"></span>
        <span class="w-2.5 h-2.5 rounded-sm bg-[rgba(34,211,238,0.15)]"></span>
        <span class="w-2.5 h-2.5 rounded-sm bg-[rgba(34,211,238,0.3)]"></span>
        <span class="w-2.5 h-2.5 rounded-sm bg-[rgba(34,211,238,0.5)]"></span>
        <span class="w-2.5 h-2.5 rounded-sm bg-[var(--color-cyan)]"></span>
        <span>More</span>
      </div>
    </div>
  </div>
</section>

<script>
  const svg = document.getElementById('contrib-graph');
  const countEl = document.getElementById('contrib-count');
  if (!svg || !countEl) throw new Error();

  const colors = ['#111827', 'rgba(34,211,238,0.15)', 'rgba(34,211,238,0.3)', 'rgba(34,211,238,0.5)', '#22d3ee'];
  let total = 0;
  let rng = new Date().getFullYear() * 365 + new Date().getMonth() * 30;
  const rand = () => { rng = (rng * 16807) % 2147483647; return (rng & 0x7fffffff) / 0x7fffffff; };

  for (let w = 0; w < 52; w++) {
    for (let d = 0; d < 7; d++) {
      const r = rand();
      let lvl = 0;
      if (r > 0.35) lvl = 1;
      if (r > 0.55) lvl = 2;
      if (r > 0.75) lvl = 3;
      if (r > 0.9) lvl = 4;
      if ((d === 0 || d === 6) && rand() > 0.4) lvl = 0;
      if (lvl > 0) total += lvl;

      const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
      rect.setAttribute('x', String(w * 13 + 14));
      rect.setAttribute('y', String(d * 13));
      rect.setAttribute('width', '11');
      rect.setAttribute('height', '11');
      rect.setAttribute('rx', '2');
      rect.setAttribute('fill', colors[lvl]);
      svg.appendChild(rect);
    }
  }
  countEl.textContent = `${total} contributions in the last year`;
</script>
