---
const navLinks = [
  { label: 'About', href: '#about' },
  { label: 'Experience', href: '#experience' },
  { label: 'Projects', href: '#projects' },
  { label: 'Skills', href: '#skills' },
  { label: 'Contact', href: '#contact' },
  { label: 'Terminal', href: '/portfolio/cli/' },
];
---

<header class="fixed top-3 left-1/2 -translate-x-1/2 z-50 w-auto max-w-[92vw]">
  <nav class="flex items-center gap-1 px-3 py-2 rounded-full bg-[rgba(255,255,255,0.03)] backdrop-blur-xl border border-[rgba(255,255,255,0.06)] shadow-[0_4px_30px_rgba(0,0,0,0.3)]">
    <!-- Coordinates (desktop only) -->
    <span class="hidden lg:block px-2 font-mono text-[10px] text-[var(--color-text-dim)] tabular-nums tracking-wider">
      12.97&deg;N 77.59&deg;E
    </span>
    <span class="hidden lg:block w-px h-3 bg-[rgba(255,255,255,0.06)]"></span>

    <!-- Clock (tablet + desktop) -->
    <span id="nav-clock" class="hidden sm:block px-2 font-mono text-[10px] text-[var(--color-text-dim)] tabular-nums">--:--</span>
    <span class="hidden sm:block w-px h-3 bg-[rgba(255,255,255,0.06)]"></span>

    <!-- Logo -->
    <a href="#hero" class="px-3 py-2 font-[var(--font-display)] font-bold text-sm text-[var(--color-text)] hover:text-[var(--color-cyan)] transition-colors" aria-label="Home">KB</a>

    <span class="w-px h-3 bg-[rgba(255,255,255,0.06)]"></span>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="relative px-3 py-2 text-[11px] text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors tracking-wide uppercase font-medium">
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile hamburger — 44x44 tap target -->
    <input type="checkbox" id="menu-toggle" class="hidden peer" aria-label="Toggle navigation menu" />
    <label for="menu-toggle" class="md:hidden flex flex-col gap-[4px] cursor-pointer p-3 ml-1 tap-target items-center justify-center" aria-label="Menu">
      <span class="w-4 h-[1.5px] bg-[var(--color-text)] transition-all peer-checked:rotate-45 peer-checked:translate-y-[5.5px]"></span>
      <span class="w-4 h-[1.5px] bg-[var(--color-text)] transition-all peer-checked:-rotate-45 peer-checked:-translate-y-[5.5px]"></span>
    </label>
  </nav>

  <!-- Mobile menu -->
  <div class="fixed inset-0 bg-[#030303]/95 backdrop-blur-xl translate-x-full peer-checked:translate-x-0 transition-transform duration-300 md:hidden flex items-center justify-center">
    <ul class="flex flex-col items-center gap-2">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="block px-8 py-4 text-xl text-[var(--color-text)] hover:text-[var(--color-cyan)] active:text-[var(--color-cyan)] transition-colors uppercase tracking-widest font-mono tap-target"
            onclick="document.getElementById('menu-toggle').checked=false">{link.label}</a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  // Clock: only run on tablet+ (where it's visible)
  if (window.matchMedia('(min-width: 640px)').matches) {
    const tick = () => {
      const el = document.getElementById('nav-clock');
      if (!el) return;
      const now = new Date();
      el.textContent = `${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;
    };
    tick();
    setInterval(tick, 30000); // Every 30s is plenty
  }
</script>
