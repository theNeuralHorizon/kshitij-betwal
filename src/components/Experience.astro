---
const entries = [
  {
    title: 'Builder Resident (R&D)',
    org: 'Zeoxia · Amsterdam (Remote)',
    period: 'Jan 2026 — Present',
    current: true,
    tags: 'AI Systems / Edge Computing / Developer Tooling',
    bullets: [
      'Ship early-stage R&D prototypes across AI systems and edge computing',
      'Build experimentation workflows and evaluation harnesses so the team iterates faster',
      'Improve internal developer tooling &mdash; the less visible work that compounds across the org',
      'Partner with senior engineers to take deep-tech products from prototype to production',
    ],
  },
];
---

<section id="experience" class="section-wrap">
  <div class="sys-label mb-4" data-animate>// EXPERIENCE</div>
  <h2 data-animate class="display-section text-[var(--color-text)] mb-3">
    Experience
  </h2>
  <p data-animate class="text-[var(--color-text-muted)] text-base sm:text-lg mb-10 max-w-xl">
    One role and a handful of hackathons so far &mdash; plus a fair number of lessons I'd rather not repeat.
  </p>

  <div class="space-y-4">
    {entries.map((e) => (
      <div class="panel overflow-hidden" data-animate>
        <div class="flex">
          <!-- Left accent bar -->
          <div class:list={['w-0.5 shrink-0', e.current ? 'bg-[var(--color-cyan)]' : 'bg-[var(--color-surface)]']}></div>

          <div class="p-6 flex-1">
            <div class="flex flex-wrap items-start justify-between gap-2 mb-1">
              <div>
                <h3 class="text-lg sm:text-xl font-[var(--font-display)] font-semibold text-[var(--color-text)]">{e.title}</h3>
                <span class="text-sm text-[var(--color-text-muted)]">{e.org}</span>
              </div>
              <div class="flex items-center gap-2">
                {e.current && (
                  <span class="flex items-center gap-1 font-mono text-[10px] text-[var(--color-green)]">
                    <span class="w-1 h-1 rounded-full bg-[var(--color-green)] animate-pulse"></span>
                    ACTIVE
                  </span>
                )}
                <span class="font-mono text-[11px] text-[var(--color-text-dim)]">{e.period}</span>
              </div>
            </div>

            <div class="font-mono text-[10px] text-[var(--color-text-dim)] tracking-wide mb-4 mt-2">{e.tags}</div>

            <ul class="space-y-1.5">
              {e.bullets.map((b) => (
                <li class="text-sm text-[var(--color-text-muted)] flex items-start gap-2">
                  <span class="text-[var(--color-text-dim)] mt-0.5">—</span> {b}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
