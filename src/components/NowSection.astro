---
const building = {
  name: 'FakeCallShield',
  desc: 'Android app detecting AI-generated & spoofed phone calls using on-device ML',
  tech: ['TypeScript', 'Android', 'ML'],
  progress: 85,
  segments: 10,
};

const learning = ['Distributed Systems Design', 'Rust for Systems Programming', 'ML Inference Optimization'];
const reading = [
  { title: 'Designing Data-Intensive Applications', author: 'M. Kleppmann' },
  { title: 'System Design Interview Vol. 2', author: 'A. Xu' },
];
---

<section class="section-wrap">
  <div class="sys-label mb-4" data-animate>// NOW</div>
  <h2 data-animate class="display-section text-[var(--color-text)] mb-3">
    Currently
  </h2>
  <p data-animate class="text-[var(--color-text-muted)] text-base sm:text-lg mb-10 max-w-xl">
    A snapshot of what's on my screen this week &mdash; the current build, the reading list,
    and whatever rabbit hole has my attention.
  </p>

  <!-- Bento grid: 2-col large + 1-col stacked -->
  <div class="grid lg:grid-cols-[2fr_1fr] gap-4">
    <!-- Building (large card) -->
    <div class="panel p-6" data-animate>
      <div class="flex items-center gap-2 mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-green)] animate-pulse"></span>
        <span class="font-mono text-[10px] text-[var(--color-green)] tracking-widest uppercase">Building</span>
      </div>
      <h3 class="text-lg font-[var(--font-display)] font-semibold text-[var(--color-text)] mb-1">{building.name}</h3>
      <p class="text-sm text-[var(--color-text-muted)] mb-4">{building.desc}</p>
      <div class="flex gap-2 mb-4">
        {building.tech.map((t) => (
          <span class="font-mono text-[10px] text-[var(--color-text-dim)]">{t}</span>
        ))}
      </div>
      <!-- Segmented progress bar -->
      <div class="flex items-center gap-2">
        <div class="flex gap-0.5 flex-1">
          {Array.from({ length: building.segments }).map((_, i) => (
            <div class:list={[
              'h-1.5 flex-1 rounded-[1px]',
              i < Math.round(building.progress / building.segments * building.segments / 10)
                ? 'bg-[var(--color-cyan)]/40'
                : 'bg-[var(--color-surface)]'
            ]}></div>
          ))}
        </div>
        <span class="font-mono text-xs text-[var(--color-cyan)] tabular-nums">{building.progress}%</span>
      </div>
    </div>

    <!-- Right stack: Learning + Reading -->
    <div class="flex flex-col gap-4">
      <div class="panel p-5 flex-1" data-animate>
        <div class="flex items-center gap-2 mb-3">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-amber)]"></span>
          <span class="font-mono text-[10px] text-[var(--color-amber)] tracking-widest uppercase">Learning</span>
        </div>
        <ul class="space-y-2">
          {learning.map((topic) => (
            <li class="text-sm text-[var(--color-text-muted)] flex items-start gap-2">
              <span class="text-[var(--color-text-dim)] mt-0.5">-</span> {topic}
            </li>
          ))}
        </ul>
      </div>

      <div class="panel p-5 flex-1" data-animate>
        <div class="flex items-center gap-2 mb-3">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-blue)]"></span>
          <span class="font-mono text-[10px] text-[var(--color-blue)] tracking-widest uppercase">Reading</span>
        </div>
        <ul class="space-y-3">
          {reading.map((b) => (
            <li>
              <div class="text-sm text-[var(--color-text)]">{b.title}</div>
              <div class="text-[11px] text-[var(--color-text-dim)]">{b.author}</div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
