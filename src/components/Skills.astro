---
import Marquee from './Marquee.astro';

const categories = [
  { label: 'LANGUAGES', skills: 'Python / C++ / JavaScript / TypeScript / Go / SQL' },
  { label: 'FRAMEWORKS', skills: 'FastAPI / React / Next.js / Node.js / Tailwind / PyTorch / Scikit-learn' },
  { label: 'CLOUD & INFRA', skills: 'AWS (EC2, Cognito) / Kubernetes / Docker / Render / Vercel / CI/CD' },
  { label: 'AI & DATA', skills: 'Machine Learning / NLP / Computer Vision / MLflow / Databricks / Power BI' },
  { label: 'CONCEPTS', skills: 'System Design / Distributed Systems / Microservices / DSA / OOP / DBMS' },
];
---

<section id="skills" class="section-wrap">
  <div class="sys-label mb-4" data-animate>// STACK</div>
  <h2 data-animate class="display-section text-[var(--color-text)] mb-3">
    The Stack
  </h2>
  <p data-animate class="text-[var(--color-text-muted)] text-base sm:text-lg mb-10 max-w-xl">
    A curated list &mdash; frameworks and infrastructure I reach for regularly, not every tool I've touched.
  </p>

  <Marquee />

  <div class="mt-10 space-y-5">
    {categories.map((cat) => (
      <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-4" data-animate>
        <span class="font-mono text-[11px] text-[var(--color-cyan)] tracking-[0.15em] w-32 shrink-0">{cat.label}</span>
        <span class="text-base text-[var(--color-text-muted)]">{cat.skills}</span>
      </div>
    ))}
  </div>
</section>
