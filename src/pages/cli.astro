---
import Layout from '../layouts/Layout.astro';
import Terminal from '../components/Terminal.astro';
---

<Layout title="Terminal — Kshitij Betwal">
  <main class="min-h-screen flex items-center justify-center px-4 py-20">
    <div class="w-full max-w-3xl" data-animate>
      <div class="text-center mb-8">
        <p class="sys-label mb-2">&gt;_ INTERACTIVE TERMINAL</p>
        <h1 class="font-[var(--font-display)] text-2xl font-bold text-[var(--color-text)]">
          Explore via <span class="text-[var(--color-cyan)]">Command Line</span>
        </h1>
      </div>

      <Terminal />

      <div class="text-center mt-6">
        <a href="/portfolio/" class="text-[var(--color-text-dim)] hover:text-[var(--color-text-muted)] transition-colors text-sm font-mono">
          &larr; Back to portfolio
        </a>
      </div>
    </div>
  </main>
</Layout>
